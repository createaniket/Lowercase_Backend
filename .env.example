# ---- Database ----
DBURL=your_mongodb_connection_string

# ---- JWT secrets ----
UserTokenKey=your_user_jwt_secret
AdminTokenKey=your_admin_jwt_secret

# ---- WordPress form key ----
WP_API_KEY=your_wp_api_key

# ---- Twilio (WhatsApp) ----
TWILIO_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
ADMIN_WHATSAPP=+44xxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=+14155238886
CONTENTTWILIOID=your_twilio_content_template_sid

# ---- Google Cloud Storage ----
GCSPROJECTID=lowercase-events-albums
GCSBUCKETNAME=lowercase-photos

# ---- Photo serving (NEW) ----
# Public base URL that maps to your bucket's photos/ prefix via the load balancer.
PHOTO_PUBLIC_BASE=https://lowercaseevents.com/photos

# ---- Server ----
PORT=9000
